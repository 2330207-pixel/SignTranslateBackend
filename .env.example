# -------------------------------------------------------------------------
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" real a git (ya está en .gitignore).
# -------------------------------------------------------------------------

# Cadena de conexión a PostgreSQL. En Railway la encuentras en:
# tu proyecto -> servicio Postgres -> pestaña "Variables" -> DATABASE_URL
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_bd

# Puerto en el que arranca el servidor Express.
# En Railway NO necesitas fijarlo: Railway inyecta su propia variable PORT.
PORT=8080

# development | production
NODE_ENV=development

# Secreto para firmar los access tokens JWT. Genera uno fuerte con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=reemplaza_esto_con_una_cadena_larga_y_aleatoria

# Client ID de OAuth 2.0 de Google (tipo "Android" o "Web", el mismo que
# uses en la app). Se obtiene en Google Cloud Console -> Credenciales.
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com

# Origen permitido para CORS. En producción, restringe esto en vez de "*".
CORS_ORIGIN=*
